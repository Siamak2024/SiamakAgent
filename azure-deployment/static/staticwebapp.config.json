{
  "routes": [
    {
      "route": "/api/*",
      "allowedRoles": ["authenticated", "anonymous"]
    },
    {
      "route": "/NexGenEA/NexGenEA_V11.html",
      "allowedRoles": ["anonymous"]
    },
    {
      "route": "/NexGenEA/*",
      "allowedRoles": ["anonymous"]
    },
    {
      "route": "/*",
      "allowedRoles": ["anonymous"]
    }
  ],
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/NexGenEA/*", "/EA2_Toolkit/*", "/css/*", "/js/*", "/api/*", "/data/*", "/scripts/*"]
  },
  "mimeTypes": {
    ".json": "application/json",
    ".js": "text/javascript",
    ".html": "text/html",
    ".css": "text/css",
    ".md": "text/markdown"
  },
  "globalHeaders": {
    "Cache-Control": "no-cache, no-store, must-revalidate"
  },
  "platform": {
    "apiRuntime": "node:18"
  }
}
