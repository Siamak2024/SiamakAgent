{
  "routes": [
    {
      "route": "/api/*",
      "allowedRoles": ["authenticated", "anonymous"]
    },
    {
      "route": "/manifesto.html",
      "serve": "/manifesto.html",
      "statusCode": 200
    },
    {
      "route": "/login.html",
      "serve": "/login.html",
      "statusCode": 200
    },
    {
      "route": "/*",
      "serve": "/index.html",
      "statusCode": 200
    }
  ],
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/manifesto.html", "/login.html", "*.{css,scss,js,png,gif,ico,jpg,jpeg,svg,woff,woff2}"]
  },
  "platform": {
    "apiRuntime": "node:18"
  }
}
