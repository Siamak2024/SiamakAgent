{
  "routes": [
    {
      "route": "/api/*",
      "allowedRoles": ["authenticated", "anonymous"]
    }
  ],
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["**.html", "**.css", "**.js", "**.mjs", "**.json", "**.png", "**.jpg", "**.jpeg", "**.gif", "**.svg", "**.ico", "**.woff", "**.woff2"]
  },
  "platform": {
    "apiRuntime": "node:18"
  }
}
