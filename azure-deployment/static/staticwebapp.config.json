{
  "routes": [
    {
      "route": "/api/*",
      "allowedRoles": ["authenticated", "anonymous"]
    }
  ],
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["*.html", "*.{css,scss,js,png,gif,ico,jpg,jpeg,svg,woff,woff2,json,mjs}"]
  },
  "platform": {
    "apiRuntime": "node:18"
  }
}
