{
  "name": "ea-platform-backend",
  "version": "1.0.0",
  "description": "Backend server for AI Enterprise Architecture Platform",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "dev:open": "node -e \"const {exec}=require('child_process');const s=require('child_process').spawn('node',['server.js'],{stdio:'inherit'});setTimeout(()=>exec('start http://localhost:3000'),2000);\"",
    "setup": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\dev-start.ps1"
  },
  "keywords": [
    "enterprise-architecture",
    "ai",
    "backend"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "body-parser": "^1.20.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "node-fetch": "^3.3.2",
    "sqlite3": "^5.1.6",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "nodemon": "^3.0.1"
  }
}
