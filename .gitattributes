# Normalize text files by default
* text=auto

# Keep source and docs as LF
*.html text eol=lf
*.js text eol=lf
*.mjs text eol=lf
*.css text eol=lf
*.md text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.txt text eol=lf
*.env text eol=lf

# Keep Windows scripts as CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.docx binary
*.zip binary
*.db binary
